<Project>
  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <DevProjexVersion Condition="'$(DevProjexVersion)'==''">4.8</DevProjexVersion>
    <DevProjexAssemblyVersion Condition="'$(DevProjexAssemblyVersion)'==''">4.8.0.0</DevProjexAssemblyVersion>
    <DevProjexFileVersion Condition="'$(DevProjexFileVersion)'==''">$(DevProjexAssemblyVersion)</DevProjexFileVersion>
    <DevProjexInformationalVersion Condition="'$(DevProjexInformationalVersion)'==''">$(DevProjexVersion)</DevProjexInformationalVersion>
    <DevProjexStorePackageVersion Condition="'$(DevProjexStorePackageVersion)'==''">4.8.0.0</DevProjexStorePackageVersion>
    <Version>$(DevProjexVersion)</Version>
    <AssemblyVersion>$(DevProjexAssemblyVersion)</AssemblyVersion>
    <FileVersion>$(DevProjexFileVersion)</FileVersion>
    <InformationalVersion>$(DevProjexInformationalVersion)</InformationalVersion>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)'=='ReleaseStore'">
    <DefineConstants>$(DefineConstants);DEVPROJEX_STORE</DefineConstants>
    <RuntimeIdentifiers>win-x64;win-arm64</RuntimeIdentifiers>
  </PropertyGroup>
</Project>
