<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DevProjex.Avalonia.ViewModels"
             x:Class="DevProjex.Avalonia.Views.SearchBarView"
             x:DataType="vm:MainWindowViewModel">
  <Border Classes="search-panel" IsEnabled="{Binding IsProjectLoaded}" UseLayoutRounding="True">
    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*" ColumnSpacing="8" Margin="12,6">
      <TextBox Name="SearchBox"
               Grid.Column="0"
               Watermark="{Binding MenuSearch}"
               Text="{Binding SearchQuery, Mode=TwoWay}"
               Width="260"
               FocusAdorner="{x:Null}"
               KeyDown="OnSearchKeyDown" />
      <Button Grid.Column="1" Content="▲" Width="32" Click="OnSearchPrev" />
      <Button Grid.Column="2" Content="▼" Width="32" Click="OnSearchNext" />
      <Button Grid.Column="3" Content="✕" Width="32" Click="OnSearchClose" />
      <TextBlock Grid.Column="4"
                 Text="{Binding SearchMatchSummaryText}"
                 IsVisible="{Binding SearchMatchSummaryVisible}"
                 FontSize="16"
                 Opacity="0.92"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Right"
                 Margin="12,0,4,0" />
    </Grid>
  </Border>
</UserControl>
